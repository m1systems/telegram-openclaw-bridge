{
  "Telegram": {
    "BotToken": "PASTE_TELEGRAM_BOT_TOKEN_HERE",
    "AllowedUserIds": [
      123456789
    ],
    "Unauthorized": {
      "RespondOnce": true,
      "ResponseText": "Unauthorized.",
      "PermanentlyMuteAfterFirstResponse": true
    },
    "Polling": {
      "TimeoutSeconds": 25,
      "IdleDelayMilliseconds": 500
    },
    "RateLimit": {
      "WindowSeconds": 60,
      "MaxCommandsPerWindow": 10,
      "ViolationMuteMinutes": 10,
      "ViolationResponseText": "Rate limit exceeded. Try again later."
    }
  },
  "OpenClaw": {
    "BaseUrl": "http://127.0.0.1:18789",
    "ChatEndpoint": "/v1/chat/completions"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  }
}